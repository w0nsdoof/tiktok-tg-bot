BOT_TOKEN=your-telegram-bot-token
# Admin user IDs — can approve/deny access requests and add users by forwarding
ADMIN_USER_IDS=[123456789]
# Seed user IDs — imported as regular (non-admin) users on first startup
ALLOWED_USER_IDS=[987654321,111222333]
MAX_DURATION=300
MAX_FILE_SIZE=50
MAX_CONCURRENT_DOWNLOADS=3
DOWNLOAD_DIR=/tmp/tg-bot-downloads
DATA_DIR=data
LOG_LEVEL=INFO
LOG_JSON=false
# Optional: Postgres DSN for usage analytics; unset = analytics disabled
# ANALYTICS_DSN=postgresql://user:pass@host:5432/dbname
